# =============================================
# Telegram YouTube Summarizer Bot - Environment
# =============================================

# --- Required ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Get from https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY

# --- Groq Model Configuration ---
# Fast model for Q&A (low latency)
GROQ_FAST_MODEL=llama-3.1-8b-instant
# Quality model for summaries & deepdives
GROQ_QUALITY_MODEL=llama-3.3-70b-versatile

# --- Optional Tuning ---
# Max transcript tokens to send per LLM request (default: 60000)
MAX_TRANSCRIPT_TOKENS=60000

# Session timeout in seconds (default: 7200 = 2 hours)
SESSION_TIMEOUT=7200

# Default language for bot responses (default: en)
DEFAULT_LANGUAGE=en

# OpenClaw Gateway URL (if using OpenClaw routing)
OPENCLAW_GATEWAY_URL=http://localhost:18789
